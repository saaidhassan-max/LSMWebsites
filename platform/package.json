{
  "name": "lsm-platform",
  "version": "0.0.1",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:ssm": "npm run dev --workspace=apps/ssm",
    "build:ssm": "npm run build --workspace=apps/ssm",
    "dev:sfb": "npm run dev --workspace=apps/sfb",
    "build:sfb": "npm run build --workspace=apps/sfb",
    "dev:sfsg": "npm run dev --workspace=apps/sfsg",
    "build:sfsg": "npm run build --workspace=apps/sfsg",
    "dev:sfbets": "npm run dev --workspace=apps/sfbets",
    "build:sfbets": "npm run build --workspace=apps/sfbets",
    "dev:ontario": "npm run dev --workspace=apps/ontario",
    "build:ontario": "npm run build --workspace=apps/ontario",
    "dev:cms": "npm run dev --workspace=apps/cms",
    "build:cms": "npm run build --workspace=apps/cms",
    "storybook": "npm run storybook --workspace=packages/ui",
    "build-storybook": "npm run build-storybook --workspace=packages/ui"
  },
  "devDependencies": {
    "turbo": "^2.3.3"
  }
}
